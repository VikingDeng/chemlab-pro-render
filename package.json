{
  "name": "chemlab_workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "check:api": "node --check server/index.mjs",
    "start:api": "node server/index.mjs",
    "test": "node ./node_modules/typescript/bin/tsc -p ./tsconfig.test.json && node --test ./.test-dist/tests/challengeGuidance.test.js ./tests/lavoisierApi.test.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:full": "./run_dev.sh",
    "start": "node server/index.mjs",
    "electron:dev": "npm run build && electron .",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "package:mac": "npm run build && electron-builder --mac zip --publish never",
    "package:win": "npm run build && electron-builder --win portable --x64 --publish never",
    "package:win:cn": "npm run build && ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win portable --x64 --publish never"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.chemlab.pro",
    "productName": "ChemLab Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "description": "Interactive chemistry lab simulator with Lavoisier AI assistant.",
  "author": "ChemLab Pro"
}
